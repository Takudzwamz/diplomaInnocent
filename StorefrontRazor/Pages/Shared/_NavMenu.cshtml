@using Core.Interfaces
@using Microsoft.AspNetCore.Identity
@using Core.Entities

@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager
@inject ISiteSettingsService SettingsService
@{
    var settings = await SettingsService.GetSettingsAsync();
    var storeName = settings.GetValueOrDefault("StoreName");
    var logoUrl = settings.GetValueOrDefault("StoreLogoUrl");
}

@{
    // Fetch the full AppUser object to access custom properties like FirstName
    var currentUser = await UserManager.GetUserAsync(User);
}

<nav class="navbar navbar-expand-lg bg-body-tertiary shadow-sm mb-3 sticky-top">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center" asp-page="/Index">
            @if (!string.IsNullOrEmpty(logoUrl))
            {
                <img src="@logoUrl" alt="@storeName Logo" style="height: 30px; margin-right: 10px;" />
            }
            else
            {
                <span class="bi bi-shop-window me-2"></span>
            }
            @storeName
        </a>
        @if (!User.IsInRole("Admin"))
        {
            <div class="d-flex align-items-center ms-auto me-4">
                @await Component.InvokeAsync("Cart")
            </div>
        }
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
            aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link" asp-page="/Products/Index">Товары</a>
                </li>
                 <li class="nav-item">
                    <a class="nav-link" asp-page="/Contact">Контакты</a>
                </li>
            </ul>

            <ul class="navbar-nav ms-auto">

                @if (SignInManager.IsSignedIn(User) && currentUser != null)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle me-1"></i> Hi, @currentUser.FirstName!
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end mb-2">
                            @if (!User.IsInRole("Admin"))
                            {
                            <li><a class="dropdown-item" asp-page="/Account/MyWishlist"><i class="bi bi-heart-fill me-2"></i>Избранное</a></li>
                            <li><a class="dropdown-item" asp-page="/Orders/Index"><i class="bi bi-receipt me-2"></i>Заказы</a></li>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/Admin/Index"><i class="bi bi-shield-lock-fill me-2"></i>Панель управления</a></li>
                            }
                            
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form method="post" asp-page="/Account/Logout">
                                    <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right me-2"></i>Выйти</button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Account/Register">Регистрация</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Account/Login">Войти</a>
                    </li>
                }
                <partial name="_ThemeSwitcherPartial" />
            </ul>
        </div>
    </div>
</nav>

