@section Scripts {
    <partial name="_ValidationScriptsPartial" />
     <script src="https://cdn.jsdelivr.net/npm/drift-zoom@1.5.1/dist/Drift.min.js"></script>
    <script>
        // Pass data from the C# model to our global site.js file
        const productVariants = @Json.Serialize(Model.Product.Variants);
        const productImages = @Json.Serialize(Model.Product.Images);
        const cartData = @Json.Serialize(Model.Cart);
    </script>
    <script>


        // --- START OF NEW SCRIPT LOGIC ---
        let drift; // Variable to hold our magnifier instance

        // Function to initialize or re-initialize the magnifier
        function initializeDrift() {
            // If a magnifier instance already exists, destroy it first
            if (drift) {
                drift.disable();
            }

            const mainImage = document.getElementById('mainProductImage');
            const pane = document.querySelector('.zoom-pane-container');
            
            // Create a new Drift instance
            drift = new Drift(mainImage, {
                paneContainer: pane,
                inlinePane: 768, // The zoom appears over the image on screens < 768px wide
                zoomFactor: 3, // How much to magnify
                hoverBoundingBox: true
            });
        }


        function selectImage(imageUrl) {
            const mainImage = document.getElementById('mainProductImage');
            if(!mainImage) return;
            mainImage.src = imageUrl;
            mainImage.dataset.zoom = imageUrl;

            document.querySelectorAll('.thumbnail-img').forEach(img => img.classList.remove('active'));
            
            // --- THIS IS THE FIX ---
            // Find the correct thumbnail by its 'src' attribute instead of relying on an event object.
            const newActiveThumb = document.querySelector(`.thumbnail-img[src="${imageUrl}"]`);
            if (newActiveThumb) {
                newActiveThumb.classList.add('active');
            }
            
            initializeDrift();
        }

        document.addEventListener('DOMContentLoaded', function () {
            initializeDrift(); // Initialize Drift when the page first loads
        });
        // --- END OF NEW SCRIPT LOGIC ---

        // --- ADD THIS SCRIPT for the star rating ---
        const ratingInput = document.getElementById('ratingInput');
        const stars = document.querySelectorAll('#star-rating-container i');

        function setRating(rating) {
            ratingInput.value = rating; // Update the hidden input
            updateStars(rating);
        }

        function updateStars(rating) {
            stars.forEach(star => {
                if (star.dataset.value <= rating) {
                    star.classList.replace('bi-star', 'bi-star-fill');
                } else {
                    star.classList.replace('bi-star-fill', 'bi-star');
                }
            });
        }
    </script>
}

@section StructuredData {
    @{
        var productUrl = $"{ViewContext.HttpContext.Request.Scheme}://{ViewContext.HttpContext.Request.Host}{ViewContext.HttpContext.Request.Path}";
        var sellerName = ViewData["StoreName"]?.ToString() ?? "Store";
        var productImages = Model.Product.Images.Select(i => i.Url).ToList();
        if (!productImages.Any()) { productImages.Add(Model.Product.PictureUrl); }
        var isVariable = Model.Product.ProductKind == Core.Entities.ProductKind.Variable && Model.Product.Variants.Any();
        var escapedName = Model.Product.Name.Replace("\"", "\\\"");
        var escapedDesc = Model.Product.Description.Replace("\"", "\\\"").Replace("\n", " ").Replace("\r", "");
    }
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "Product",
        "name": "@Html.Raw(escapedName)",
        "description": "@Html.Raw(escapedDesc)",
        "productID": "@Model.Product.Id",
        "sku": "SKU-@Model.Product.Id",
        "url": "@productUrl",
        "mainEntityOfPage": {
            "@@type": "WebPage",
            "@@id": "@productUrl"
        },
        "image": [@Html.Raw(string.Join(", ", productImages.Select(url => $"\"{url}\"")))],
        "brand": {
            "@@type": "Brand",
            "name": "@Model.Product.ProductBrand"
        },
        "category": "@Model.Product.ProductCategory",
        "itemCondition": "https://schema.org/NewCondition",
        @if (isVariable)
        {
            var variantPrices = Model.Product.Variants.Select(v => v.DiscountedPrice ?? v.Price).ToList();
            var anyInStock = Model.Product.Variants.Any(v => v.QuantityInStock > 0);
            <text>"offers": {
            "@@type": "AggregateOffer",
            "lowPrice": "@variantPrices.Min().ToString(System.Globalization.CultureInfo.InvariantCulture)",
            "highPrice": "@variantPrices.Max().ToString(System.Globalization.CultureInfo.InvariantCulture)",
            "priceCurrency": "ZAR",
            "offerCount": "@Model.Product.Variants.Count",
            "availability": "@(anyInStock ? "https://schema.org/InStock" : "https://schema.org/OutOfStock")",
            "url": "@productUrl",
            "seller": {
                "@@type": "Organization",
                "name": "@sellerName"
            }
        }</text>
        }
        else
        {
            <text>"offers": {
            "@@type": "Offer",
            "price": "@((Model.Product.DiscountedPrice ?? Model.Product.Price).ToString(System.Globalization.CultureInfo.InvariantCulture))",
            "priceCurrency": "ZAR",
            "availability": "@(Model.Product.QuantityInStock > 0 ? "https://schema.org/InStock" : "https://schema.org/OutOfStock")",
            "url": "@productUrl",
            "itemCondition": "https://schema.org/NewCondition",
            "priceValidUntil": "@DateTime.UtcNow.AddMonths(6).ToString("yyyy-MM-dd")",
            "seller": {
                "@@type": "Organization",
                "name": "@sellerName"
            }
        }</text>
        }
        @if (Model.Product.ReviewCount > 0)
        {
            <text>,
        "aggregateRating": {
            "@@type": "AggregateRating",
            "ratingValue": "@Model.Product.AverageRating.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)",
            "bestRating": "5",
            "worstRating": "1",
            "reviewCount": "@Model.Product.ReviewCount"
        }</text>
        }
        @if (Model.Product.Reviews.Any())
        {
            <text>,
        "review": [
            @for (var i = 0; i < Math.Min(Model.Product.Reviews.Count, 10); i++)
            {
                var review = Model.Product.Reviews[i];
                if (i > 0) { <text>,</text> }
                <text>{
                "@@type": "Review",
                "author": {
                    "@@type": "Person",
                    "name": "@review.ReviewerName"
                },
                "reviewRating": {
                    "@@type": "Rating",
                    "ratingValue": "@review.Rating",
                    "bestRating": "5",
                    "worstRating": "1"
                },
                "reviewBody": "@Html.Raw(review.Comment?.Replace("\"", "\\\"").Replace("\n", " ").Replace("\r", "") ?? "")",
                "datePublished": "@review.ReviewDate.ToString("yyyy-MM-dd")"
            }</text>
            }
        ]</text>
        }
        @if (Model.Product.Options.Any())
        {
            <text>,
        "additionalProperty": [
            @for (var i = 0; i < Model.Product.Options.Count; i++)
            {
                var option = Model.Product.Options[i];
                var optionValues = string.Join(", ", option.Values.Select(v => v.Name));
                if (i > 0) { <text>,</text> }
                <text>{
                "@@type": "PropertyValue",
                "name": "@option.Name",
                "value": "@Html.Raw(optionValues.Replace("\"", "\\\""))"
            }</text>
            }
        ]</text>
        }
        @if (isVariable)
        {
            <text>,
        "hasVariant": [
            @for (var vi = 0; vi < Math.Min(Model.Product.Variants.Count, 20); vi++)
            {
                var variant = Model.Product.Variants[vi];
                var variantPrice = (variant.DiscountedPrice ?? variant.Price).ToString(System.Globalization.CultureInfo.InvariantCulture);
                var variantOptionNames = new List<string>();
                foreach (var optValId in variant.OptionValueIds)
                {
                    foreach (var opt in Model.Product.Options)
                    {
                        var val = opt.Values.FirstOrDefault(v => v.Id == optValId);
                        if (val != null) { variantOptionNames.Add($"{opt.Name}: {val.Name}"); }
                    }
                }
                var variantName = variantOptionNames.Any()
                    ? $"{Model.Product.Name} - {string.Join(", ", variantOptionNames)}"
                    : $"{Model.Product.Name} - Variant {variant.Id}";
                if (vi > 0) { <text>,</text> }
                <text>{
                "@@type": "Product",
                "name": "@Html.Raw(variantName.Replace("\"", "\\\""))",
                "sku": "VAR-@variant.Id",
                "offers": {
                    "@@type": "Offer",
                    "price": "@variantPrice",
                    "priceCurrency": "ZAR",
                    "availability": "@(variant.QuantityInStock > 0 ? "https://schema.org/InStock" : "https://schema.org/OutOfStock")",
                    "url": "@productUrl",
                    "itemCondition": "https://schema.org/NewCondition",
                    "seller": {
                        "@@type": "Organization",
                        "name": "@sellerName"
                    }
                }
            }</text>
            }
        ]</text>
        }
    }
    </script>
}