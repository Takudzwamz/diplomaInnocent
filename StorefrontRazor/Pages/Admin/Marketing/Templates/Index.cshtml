@page
@model StorefrontRazor.Pages.Admin.Marketing.Templates.IndexModel
@{
    ViewData["Title"] = "Маркетинг";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@ViewData["Title"]</h1>
    <a asp-page="./Create" class="btn btn-primary">
        <i class="bi bi-plus-circle-fill me-2"></i>Создать
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Тема</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var template in Model.Templates)
                    {
                        <tr>
                            <td><strong>@template.Name</strong></td>
                            <td>@template.Subject</td>
                            <td class="text-end">
                                <div class="d-flex flex-wrap justify-content-end gap-2">
                                <a asp-page="./Edit" asp-route-id="@template.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-fill"></i> 
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@template.Id" class="d-inline" onsubmit="return confirm('Вы уверены, что хотите удалить этот элемент?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash-fill"></i> 
                                    </button>
                                </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>