@page
@model StorefrontRazor.Pages.Admin.Marketing.Templates.CreateModel
@{
    ViewData["Title"] = "Создать";
}

<h1>@ViewData["Title"]</h1>
<p class="text-muted">Создайте многоразовый HTML-шаблон письма. Используйте подстановки: <code>{CouponCode}</code>, <code>{DiscountValue}</code>, <code>{Headline}</code> для динамического контента.</p>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="form-group mb-3">
        <label asp-for="Template.Name"></label>
        <input asp-for="Template.Name" class="form-control" />
    </div>
    <div class="form-group mb-3">
        <label asp-for="Template.Subject"></label>
        <input asp-for="Template.Subject" class="form-control" />
    </div>
    <div class="form-group mb-3">
        <label asp-for="Template.Body">Тело письма (HTML)</label>
        <textarea asp-for="Template.Body" class="form-control" rows="20"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Сохранить</button>
</form>