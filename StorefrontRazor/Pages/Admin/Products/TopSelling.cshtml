@page
@model StorefrontRazor.Pages.Admin.Products.TopSellingModel
@{
    ViewData["Title"] = "Самые продаваемые товары";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@ViewData["Title"]</h1>
    <a asp-page="/Admin/Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Назад к панели управления
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (Model.ProductPagination.Data.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 80px;">Изображение</th>
                            <th>Товар / Вариант</th>
                            <th>Всего продано</th>
                            <th>Общая выручка</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.ProductPagination.Data)
                        {
                            <tr>
                                <td><img src="@product.PictureUrl" alt="@product.ProductName" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: cover;"/></td>
                                <td>
                                    <a asp-page="/Products/Details" asp-route-id="@product.ProductId" class="fw-bold text-decoration-none" target="_blank">
                                        @product.ProductName <i class="bi bi-box-arrow-up-right small"></i>
                                    </a>
                                    @if (!string.IsNullOrEmpty(product.SelectedOptions))
                                    {
                                        <small class="d-block text-muted">@product.SelectedOptions</small>
                                    }
                                </td>
                                <td><span class="fs-5">@product.TotalQuantitySold</span></td>
                                <td><span class="fs-5 fw-bold">@product.TotalRevenue.ToString("C")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            @* --- This card is shown if no products have been sold --- *@
            <div class="text-center p-4">
                <h4 class="text-muted">Товары ещё не продавались</h4>
                <p>Как только вы совершите первую продажу, ваши топ-товары появятся здесь.</p>
                <a asp-page="/Admin/Index" class="btn btn-primary mt-2">
                    <i class="bi bi-arrow-left"></i> Назад к панели управления
                </a>
            </div>
        }
    </div>
</div>

@* --- PAGINATION CONTROLS (REPLACED PARTIAL) --- *@
@if (Model.ProductPagination.TotalPages > 1)
{
    <div class="d-flex justify-content-center mt-4">
        <nav>
            <ul class="pagination">
                @{
                    var currentPage = Model.PageIndex;
                    var totalPages = Model.ProductPagination.TotalPages;
                    var maxPagesToShow = 5;
                    var startPage = 1;
                    var endPage = totalPages;

                    if (totalPages > maxPagesToShow)
                    {
                        var pagesToShowHalf = maxPagesToShow / 2;
                        startPage = Math.Max(1, currentPage - pagesToShowHalf);
                        endPage = startPage + maxPagesToShow - 1;

                        if (endPage > totalPages)
                        {
                            endPage = totalPages;
                            startPage = Math.Max(1, endPage - maxPagesToShow + 1);
                        }
                    }

                    // --- Previous Button ---
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a asp-page="/Admin/Products/TopSelling" asp-route-PageIndex="@(currentPage - 1)"
                           class="page-link" aria-label="Previous" tabindex="@(currentPage == 1 ? "-1" : null)">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>

                    // --- First Page ---
                    @if (startPage > 1)
                    {
                        <li class="page-item">
                            <a asp-page="/Admin/Products/TopSelling" asp-route-PageIndex="1" class="page-link">1</a>
                        </li>
                        @if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    // --- Page Numbers ---
                    @for (var i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a asp-page="/Admin/Products/TopSelling" asp-route-PageIndex="@i" class="page-link">@i</a>
                        </li>
                    }

                    // --- Last Page ---
                    @if (endPage < totalPages)
                    {
                        @if (endPage < totalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a asp-page="/Admin/Products/TopSelling" asp-route-PageIndex="@totalPages" class="page-link">@totalPages</a>
                        </li>
                    }

                    // --- Next Button ---
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a asp-page="/Admin/Products/Topselling" asp-route-PageIndex="@(currentPage + 1)"
                           class="page-link" aria-label="Next" tabindex="@(currentPage == totalPages ? "-1" : null)">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}