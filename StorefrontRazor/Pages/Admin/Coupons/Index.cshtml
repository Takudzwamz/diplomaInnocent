@page
@model StorefrontRazor.Pages.Admin.Coupons.IndexModel
@{
    ViewData["Title"] = "Управление купонами";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@ViewData["Title"]</h1>
    <a asp-page="./Create" class="btn btn-primary">
        <i class="bi bi-plus-circle-fill me-2"></i>Создать
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @* --- THIS IS THE FIX --- *@
        @if (Model.Coupons.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Код</th>
                            <th>Описание</th>
                            <th>Значение</th>
                            <th>Статус</th>
                            <th>Срок действия</th>
                            <th class="text-center">Usage</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var coupon in Model.Coupons)
                        {
                            <tr>
                                <td><strong class="text-primary">@coupon.Code</strong></td>
                                <td>@coupon.Description</td>
                                <td>@Model.GetDiscountValue(coupon)</td>
                                <td>
                                    @if (coupon.IsActive)
                                    {
                                        <span class="badge text-bg-success">Активен</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">Неактивен</span>
                                    }
                                </td>
                                <td>
                                    @(coupon.ValidFrom?.ToShortDateString() ?? "...") - @(coupon.ValidUntil?.ToShortDateString() ?? "...")
                                </td>
                                <td class="text-center">
                                    @coupon.UsageCount / @(coupon.UsageLimit?.ToString() ?? "∞")
                                </td>
                                <td class="text-end">
                                    <div class="d-flex flex-wrap justify-content-end gap-2">
                                    <a asp-page="./Edit" asp-route-id="@coupon.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@coupon.Id" class="d-inline" onsubmit="return confirm('Вы уверены, что хотите удалить этот купон?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            @* --- This card is shown if no coupons exist --- *@
            <div class="text-center p-4">
                <h4 class="text-muted">Купоны не найдены</h4>
                <p>Создайте первый купон на скидку.</p>
                <a asp-page="./Create" class="btn btn-primary mt-2">
                    <i class="bi bi-plus-circle-fill me-2"></i>Создать купон
                </a>
            </div>
        }
        @* --- END OF FIX --- *@
    </div>
</div>