@page
@model StorefrontRazor.Pages.Admin.Hero.IndexModel
@{
    ViewData["Title"] = "Слайды баннера";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@ViewData["Title"]</h1>
    <a asp-page="./Create" class="btn btn-primary">
        <i class="bi bi-plus-circle-fill me-2"></i>Создать
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @* --- THIS IS THE FIX --- *@
        @if (Model.Slides.Any())
        {
            <table class="table table-hover align-middle">
                @foreach (var slide in Model.Slides.OrderBy(s => s.DisplayOrder))
                {
                    <tr>
                        <td><img src="@slide.ImageUrl" alt="@slide.Title hero slide" style="width: 150px; object-fit: cover; border-radius: 5px;" /></td>
                        <td><strong>@slide.Title</strong><br /><small class="text-muted">@slide.Subtext</small></td>
                        <td class="text-end">
                            <div class="d-flex flex-wrap justify-content-end gap-2">
                                <a asp-page="./Edit" asp-route-id="@slide.Id" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@slide.Id" class="m-0"
                                      onsubmit="return confirm('Вы уверены, что хотите удалить этот элемент?');">
                                    <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash-fill"></i></button>
                                </form>
                            </div>
                        </td>

                    </tr>
                }
            </table>
        }
        else
        {
            @* --- This card is shown if no slides exist --- *@
            <div class="text-center p-4">
                <h4 class="text-muted">Данные отсутствуют.</h4>
                <p>Добавьте первый слайд карусели.</p>
                <a asp-page="./Create" class="btn btn-primary mt-2">
                    <i class="bi bi-plus-circle-fill me-2"></i>Создать
                </a>
            </div>
        }
        @* --- END OF FIX --- *@
    </div>
</div>