@page
@model StorefrontRazor.Pages.Admin.Recommendations.IndexModel

@{
    ViewData["Title"] = "Система рекомендаций и A/B-тестирование";
}

<div class="container-fluid">
    <h2 class="mb-4"><i class="bi bi-graph-up me-2"></i>Система рекомендаций и A/B-тестирование</h2>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <p class="text-muted mb-0">Метрики адаптивной системы рекомендаций, управление A/B-тестами и экспериментальная оценка.</p>
        <a asp-page="/Admin/Recommendations/Evaluation" class="btn btn-outline-primary">
            <i class="bi bi-clipboard-data me-1"></i> Запустить офлайн-оценку
        </a>
    </div>

    @* --- Overview Stats --- *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h3 class="text-primary">@Model.TotalInteractions.ToString("N0")</h3>
                    <small class="text-muted">Всего взаимодействий</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h3 class="text-success">@Model.TotalUsers.ToString("N0")</h3>
                    <small class="text-muted">Отслеживаемых пользователей</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h3 class="text-info">@Model.TotalExperiments</h3>
                    <small class="text-muted">Эксперименты</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    @if (Model.SystemMetrics != null)
                    {
                        <h3 class="text-warning">@Model.SystemMetrics.OverallCTR.ToString("P2")</h3>
                    }
                    else
                    {
                        <h3 class="text-warning">—</h3>
                    }
                    <small class="text-muted">Общий CTR (30 дн.)</small>
                </div>
            </div>
        </div>
    </div>

    @* --- System Metrics --- *@
    @if (Model.SystemMetrics != null)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent">
                <h5 class="mb-0"><i class="bi bi-bar-chart-fill me-2"></i>Системные метрики (последние 30 дней)</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="p-3 bg-body-secondary rounded">
                            <div class="text-muted small">Показы</div>
                            <div class="fs-4 fw-bold">@Model.SystemMetrics.TotalImpressions.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 bg-body-secondary rounded">
                            <div class="text-muted small">Клики</div>
                            <div class="fs-4 fw-bold">@Model.SystemMetrics.TotalClicks.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 bg-body-secondary rounded">
                            <div class="text-muted small">Добавлено в корзину</div>
                            <div class="fs-4 fw-bold">@Model.SystemMetrics.TotalAddToCarts.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 bg-body-secondary rounded">
                            <div class="text-muted small">Покупки</div>
                            <div class="fs-4 fw-bold">@Model.SystemMetrics.TotalPurchases.ToString("N0")</div>
                        </div>
                    </div>
                </div>

                @if (Model.SystemMetrics.ByStrategy.Any())
                {
                    <h6 class="mt-4">Показатели по стратегиям</h6>
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th>Стратегия</th>
                                <th>Показы</th>
                                <th>Клики</th>
                                <th>Покупки</th>
                                <th>CTR</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var strategy in Model.SystemMetrics.ByStrategy)
                            {
                                <tr>
                                    <td><span class="badge bg-primary">@strategy.Strategy</span></td>
                                    <td>@strategy.Impressions.ToString("N0")</td>
                                    <td>@strategy.Clicks.ToString("N0")</td>
                                    <td>@strategy.Purchases.ToString("N0")</td>
                                    <td>@strategy.CTR.ToString("P2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }

    @* --- Active A/B Test Experiment --- *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-clipboard-data me-2"></i>A/B-тест (эксперимент)</h5>
            @if (Model.ActiveExperiment == null)
            {
                <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createExperimentModal">
                    <i class="bi bi-plus-circle me-1"></i>Новый эксперимент
                </button>
            }
        </div>
        <div class="card-body">
            @if (Model.ActiveExperiment != null)
            {
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h5>@Model.ActiveExperiment.Name</h5>
                        <p class="text-muted mb-1">@Model.ActiveExperiment.Description</p>
                        <small class="text-muted">
                            Started: @Model.ActiveExperiment.StartDate.ToString("yyyy-MM-dd")
                            @if (Model.ActiveExperiment.EndDate.HasValue)
                            {
                                <span> | Завершение: @Model.ActiveExperiment.EndDate.Value.ToString("yyyy-MM-dd")</span>
                            }
                        </small>
                    </div>
                    <form method="post" asp-page-handler="EndExperiment">
                        <input type="hidden" name="experimentId" value="@Model.ActiveExperiment.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('Завершить эксперимент?')">
                            <i class="bi bi-stop-circle me-1"></i>Завершить эксперимент
                        </button>
                    </form>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-md-6">
                        <div class="p-2 bg-body-secondary rounded text-center">
                            <small class="text-muted">Контрольная группа</small>
                            <div class="fw-bold">@Model.ActiveExperiment.ControlStrategy</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-2 bg-body-secondary rounded text-center">
                            <small class="text-muted">Тестовая группа</small>
                            <div class="fw-bold text-success">@Model.ActiveExperiment.TreatmentStrategy</div>
                        </div>
                    </div>
                </div>

                @* --- Experiment Results --- *@
                @if (Model.Metrics != null)
                {
                    <h6 class="mt-4 mb-3">Результаты эксперимента</h6>
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Метрика</th>
                                <th class="text-center">Контрольная группа</th>
                                <th class="text-center">Тестовая группа</th>
                                <th class="text-center">Прирост</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Пользователи</td>
                                <td class="text-center">@Model.Metrics.ControlUsers</td>
                                <td class="text-center">@Model.Metrics.TreatmentUsers</td>
                                <td class="text-center">—</td>
                            </tr>
                            <tr>
                                <td>Показы</td>
                                <td class="text-center">@Model.Metrics.ControlImpressions.ToString("N0")</td>
                                <td class="text-center">@Model.Metrics.TreatmentImpressions.ToString("N0")</td>
                                <td class="text-center">—</td>
                            </tr>
                            <tr>
                                <td>CTR</td>
                                <td class="text-center">@Model.Metrics.ControlCTR.ToString("P2")</td>
                                <td class="text-center">@Model.Metrics.TreatmentCTR.ToString("P2")</td>
                                <td class="text-center @(Model.Metrics.CTRLift > 0 ? "text-success" : "text-danger")">
                                    @(Model.Metrics.CTRLift > 0 ? "+" : "")@Model.Metrics.CTRLift.ToString("F1")%
                                </td>
                            </tr>
                            <tr>
                                <td>Коэффициент конверсии</td>
                                <td class="text-center">@Model.Metrics.ControlConversionRate.ToString("P2")</td>
                                <td class="text-center">@Model.Metrics.TreatmentConversionRate.ToString("P2")</td>
                                <td class="text-center @(Model.Metrics.ConversionLift > 0 ? "text-success" : "text-danger")">
                                    @(Model.Metrics.ConversionLift > 0 ? "+" : "")@Model.Metrics.ConversionLift.ToString("F1")%
                                </td>
                            </tr>
                            <tr>
                                <td>Средний чек (AOV)</td>
                                <td class="text-center">@Model.Metrics.ControlAOV.ToString("C2")</td>
                                <td class="text-center">@Model.Metrics.TreatmentAOV.ToString("C2")</td>
                                <td class="text-center @(Model.Metrics.AOVLift > 0 ? "text-success" : "text-danger")">
                                    @(Model.Metrics.AOVLift > 0 ? "+" : "")@Model.Metrics.AOVLift.ToString("F1")%
                                </td>
                            </tr>
                            <tr>
                                <td>Выручка</td>
                                <td class="text-center">@Model.Metrics.ControlRevenue.ToString("C2")</td>
                                <td class="text-center">@Model.Metrics.TreatmentRevenue.ToString("C2")</td>
                                <td class="text-center">—</td>
                            </tr>
                        </tbody>
                    </table>

                    @* Statistical Significance *@
                    <div class="mt-3 p-3 rounded @(Model.Metrics.IsStatisticallySignificant ? "bg-success-subtle" : "bg-warning-subtle")">
                        <strong>Статистическая значимость:</strong>
                        @if (Model.Metrics.IsStatisticallySignificant)
                        {
                            <span class="text-success">
                                <i class="bi bi-check-circle-fill me-1"></i>
                                Результаты статистически значимы (p = @Model.Metrics.PValueConversion.ToString("F4"))
                            </span>
                        }
                        else
                        {
                            <span class="text-warning">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                Пока не значимы. Требуется больше данных. (p = @Model.Metrics.PValueConversion.ToString("F4"))
                            </span>
                        }
                    </div>
                }
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-flask display-4 text-muted"></i>
                    <p class="mt-2 text-muted">Нет активных экспериментов. Создайте новый для запуска A/B-теста.</p>
                </div>
            }
        </div>
    </div>

    @* --- Recommendation Strategies --- *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-transparent">
            <h5 class="mb-0"><i class="bi bi-lightbulb me-2"></i>Доступные стратегии</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6><i class="bi bi-fire me-1 text-danger"></i> Популярные</h6>
                            <small class="text-muted">Рекомендует наиболее покупаемые товары. Базовая линия для тестирования.</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6><i class="bi bi-people me-1 text-info"></i> Коллаборативная фильтрация</h6>
                            <small class="text-muted">На основе покупок похожих пользователей.</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6><i class="bi bi-file-text me-1 text-primary"></i> На основе контента</h6>
                            <small class="text-muted">Схожесть товаров через AI-эмбеддинги.</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card h-100 border-success">
                        <div class="card-body">
                            <h6><i class="bi bi-stars me-1 text-success"></i> Адаптивная (гибридная)</h6>
                            <small class="text-muted">Комбинирует КФ + контент + тренды + категории. Модель диссертации.</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- Create Experiment Modal --- *@
<div class="modal fade" id="createExperimentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="CreateExperiment">
                <div class="modal-header">
                    <h5 class="modal-title">Создать A/B-тест</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Название эксперимента</label>
                        <input type="text" class="form-control" name="name" required
                            placeholder="напр., Адаптивная vs Популярные — Неделя 1" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Описание</label>
                        <textarea class="form-control" name="description" rows="2"
                            placeholder="Цель эксперимента..."></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Стратегия контрольной группы</label>
                            <select class="form-select" name="controlStrategy">
                                <option value="None">Нет (без рекомендаций)</option>
                                <option value="Popular" selected>Популярные</option>
                                <option value="CollaborativeFiltering">Коллаборативная фильтрация</option>
                                <option value="ContentBased">На основе контента</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Стратегия тестовой группы</label>
                            <select class="form-select" name="treatmentStrategy">
                                <option value="Popular">Популярные</option>
                                <option value="CollaborativeFiltering">Коллаборативная фильтрация</option>
                                <option value="ContentBased">На основе контента</option>
                                <option value="Adaptive" selected>Адаптивная (гибридная)</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label">% тестовой группы (50 = equal split)</label>
                        <input type="number" class="form-control" name="treatmentPercentage"
                            value="50" min="10" max="90" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-play-circle me-1"></i>Запустить эксперимент
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
