@page "{id:int}"
@model StorefrontRazor.Pages.Admin.Orders.DetailsModel
@{
    ViewData["Title"] = string.Format("{0} #{1}", "Детали заказа", Model.Order.Id);
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <a asp-page="./Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Назад к заказам</a>

    @if (Model.Order.Status == "PaymentReceived")
    {
        <form method="post" asp-page-handler="RefundOrder" onsubmit="return confirm('Вы уверены, что хотите оформить возврат этого заказа?');">
            <button class="btn btn-danger"><i class="bi bi-cash-coin"></i> Возврат заказа</button>
        </form>
    }
</div>

@if(TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<h1 class="mb-3">Заказ #@Model.Order.Id</h1>

<div class="d-flex flex-wrap align-items-center gap-3 text-muted mb-3">
    <span><i class="bi bi-calendar-event me-1"></i> Оформлен @Model.Order.OrderDate.ToLongDateString()</span>
    <span class="d-none d-sm-inline">|</span>
    <span class="badge @Model.GetStatusBadgeClass(Model.Order.Status) fs-6 d-flex align-items-center">
        <i class="bi bi-credit-card-fill me-2"></i> @Model.Order.Status
    </span>
    <span class="badge @Model.GetDeliveryStatusBadgeClass(Model.Order.DeliveryStatus) fs-6 d-flex align-items-center">
        <i class="bi bi-truck me-2"></i> @Model.Order.DeliveryStatus
    </span>
</div>

<div class="card mb-4 mt-4">
    <div class="card-header">Обновить статус доставки</div>
    <div class="card-body">
        <form method="post" asp-page-handler="UpdateStatus" class="row g-3">
            <div class="col-md-5">
                <label asp-for="NewStatus" class="form-label">Новый статус</label>
                <select asp-for="NewStatus" asp-items="Model.DeliveryStatusOptions" class="form-select" id="statusSelect" onchange="updateNotes()"></select>
            </div>
            <div class="col-md-5">
                <label asp-for="Notes" class="form-label">Заметки (необязательно)</label>
                <input asp-for="Notes" class="form-control" placeholder="e.g., Tracking #XYZ123" id="notesInput" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Добавить обновление</button>
            </div>
        </form>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">Заказанные товары</div>
            <ul class="list-group list-group-flush">
                @foreach (var item in Model.Order.OrderItems)
                {
                    <li class="list-group-item d-flex align-items-center">
                        <img src="@item.PictureUrl" alt="@item.ProductName" class="me-3 rounded" style="width: 60px; height: 60px; object-fit: cover;" />
                        <div class="flex-grow-1">
                            <h6 class="my-0">@item.ProductName</h6>
                            @* --- THIS IS THE FIX --- *@
                            @if (!string.IsNullOrEmpty(item.SelectedOptions))
                            {
                                <small class="text-muted d-block">@item.SelectedOptions</small>
                            }
                            <small class="text-muted">@item.Price.ToString("C") x @item.Quantity</small>
                        </div>
                        <span class="fw-bold">@((item.Price * item.Quantity).ToString("C"))</span>
                    </li>
                }
            </ul>
        </div>
        @if (Model.Order.TrackingHistory.Any())
        {
            <div class="card">
                <div class="card-header">История доставки</div>
                <ul class="list-group list-group-flush">
                    @foreach (var historyEvent in Model.Order.TrackingHistory)
                    {
                        <li class="list-group-item d-flex align-items-start">
                            <i class="@Model.GetDeliveryIconClass(historyEvent.Status) me-3 fs-4 text-primary"></i>
                            <div>
                                <strong>@historyEvent.Status</strong> - @historyEvent.EventDate.ToShortDateString()
                                @if (!string.IsNullOrEmpty(historyEvent.Notes))
                                { <p class="text-muted mb-0">@historyEvent.Notes</p> }
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header"><strong>Доставка по адресу</strong></div>
            <div class="card-body">
                <p class="card-text mb-0">
                    @Model.Order.ShippingAddress.Name @Model.Order.ShippingAddress.LastName<br>
                    @Model.Order.ShippingAddress.Line1<br>
                    @if(!string.IsNullOrEmpty(Model.Order.ShippingAddress.Line2)) {
                        @Model.Order.ShippingAddress.Line2 <br>
                    }
                    @Model.Order.ShippingAddress.City, @Model.Order.ShippingAddress.State @Model.Order.ShippingAddress.PostalCode
                </p>
                @if (!string.IsNullOrEmpty(Model.Order.ShippingAddress.PhoneNumber))
                {
                    <hr>
                    <h6 class="card-subtitle mb-2 text-muted">Контактный телефон</h6>
                    <p class="card-text mb-0"><i class="bi bi-telephone-fill me-2"></i>@Model.Order.ShippingAddress.PhoneNumber</p>
                }
                @if (!string.IsNullOrEmpty(Model.Order.ShippingAddress.DeliveryNotes))
                {
                    <hr>
                    <h6 class="card-subtitle mb-2 text-muted">Заметки к доставке</h6>
                    <p class="card-text mb-0 fst-italic">"@Model.Order.ShippingAddress.DeliveryNotes"</p>
                }
            </div>
        </div>
        <div class="card">
            <div class="card-header">Итого по заказу</div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2"><span>Подитог</span><span>@Model.Order.Subtotal.ToString("C")</span></div>
                <div class="d-flex justify-content-between mb-2"><span>Доставка</span><span>@Model.Order.ShippingPrice.ToString("C")</span></div>
                 @if (Model.Order.Discount > 0)
                {
                    <div class="d-flex justify-content-between text-success mb-2">
                        <span>Скидка</span>
                        <span>-@Model.Order.Discount.ToString("C")</span>
                    </div>
                }
                <hr />
                <div class="d-flex justify-content-between fw-bold fs-5"><span>Итого</span><span>@Model.Order.Total.ToString("C")</span></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const statusNotes = @Html.Raw(Model.StatusNotesJson);
        const statusSelect = document.getElementById('statusSelect');
        const notesInput = document.getElementById('notesInput');

        function updateNotes() {
            const selectedStatus = statusSelect.value;
            notesInput.value = statusNotes[selectedStatus] || '';
        }
    </script>
}