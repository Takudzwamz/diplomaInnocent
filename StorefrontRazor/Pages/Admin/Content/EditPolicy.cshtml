@page
@model StorefrontRazor.Pages.Admin.Content.EditPolicyModel
@{
    ViewData["Title"] = "Редактировать";
}

<h1 class="mb-4">@ViewData["Title"]</h1>
<p class="text-muted">Заполните поля ниже для обновления страницы «Политика возврата» на сайте магазина.</p>

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="PolicyInput.ReturnWindowDays"></label>
                    <input asp-for="PolicyInput.ReturnWindowDays" class="form-control" />
                    <span asp-validation-for="PolicyInput.ReturnWindowDays" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="PolicyInput.RefundTimeframe"></label>
                    <input asp-for="PolicyInput.RefundTimeframe" class="form-control" />
                    <span asp-validation-for="PolicyInput.RefundTimeframe" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PolicyInput.ContactEmail"></label>
                <input asp-for="PolicyInput.ContactEmail" class="form-control" />
                <span asp-validation-for="PolicyInput.ContactEmail" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PolicyInput.NonReturnableItems"></label>
                <textarea asp-for="PolicyInput.NonReturnableItems" class="form-control" rows="4"></textarea>
                <span asp-validation-for="PolicyInput.NonReturnableItems" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a asp-page="./Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>