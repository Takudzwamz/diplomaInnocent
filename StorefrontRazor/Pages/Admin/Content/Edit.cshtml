@page "{id:int}"
@model StorefrontRazor.Pages.Admin.Content.EditModel
@{
    ViewData["Title"] = "Редактировать";
}

<h1 class="mb-4">@Model.ContentBlock.Title</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="ContentBlock.Id" />
            <input type="hidden" asp-for="ContentBlock.Key" />
            <input type="hidden" asp-for="ContentBlock.Title" />

            <div class="form-group mb-3">
                <label asp-for="ContentBlock.Content" class="form-label">Content</label>
                <textarea asp-for="ContentBlock.Content" class="form-control" rows="10"></textarea>
                <span asp-validation-for="ContentBlock.Content" class="text-danger"></span>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" role="switch" asp-for="ContentBlock.IsHtml">
                <label class="form-check-label" asp-for="ContentBlock.IsHtml">Отображать как HTML</label>
                <small class="form-text text-muted d-block">Установите, если используете HTML-теги (ссылки, жирный текст и т.д.)</small>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a asp-page="./Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>