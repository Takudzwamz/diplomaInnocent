@page
@model StorefrontRazor.Pages.Admin.AIInsights.IndexModel
@{
    ViewData["Title"] = "AI-аналитика";
}

<style>
    /* Mobile-friendly table styles for AI Insights */
    .ai-insights-table {
        font-size: 0.875rem;
    }
    .ai-insights-table th,
    .ai-insights-table td {
        white-space: nowrap;
    }
    .ai-insights-table .reason-col {
        white-space: normal;
        min-width: 150px;
        max-width: 250px;
    }
    @@media (max-width: 768px) {
        .ai-insights-table {
            font-size: 0.75rem;
        }
        .ai-insights-table th,
        .ai-insights-table td {
            padding: 0.5rem 0.25rem;
        }
        .ai-insights-table .reason-col {
            min-width: 120px;
            max-width: 180px;
        }
    }
</style>

<div class="my-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 h2-md"><i class="bi bi-robot me-2"></i>AI-аналитика</h1>
            <p class="text-muted mb-0 small">На основе Azure OpenAI — бизнес-аналитика в реальном времени</p>
        </div>
        <button class="btn btn-primary btn-sm btn-md-lg" onclick="refreshAllInsights()">
            <i class="bi bi-arrow-clockwise me-1"></i>Обновить всё
        </button>
    </div>

@if (!Model.IsAIEnabled)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong>Сервис ИИ не настроен</strong>
        <p class="mb-0 mt-2">Сервис Azure OpenAI не настроен. Добавьте учётные данные Azure OpenAI в настройки приложения для включения ИИ-аналитики.</p>
    </div>
}
else
{
    @* Navigation Tabs *@
    <ul class="nav nav-tabs mb-4" id="insightsTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="forecast-tab" data-bs-toggle="tab" data-bs-target="#forecast" type="button" role="tab">
                <i class="bi bi-graph-up-arrow me-1"></i>Прогноз продаж
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#inventory" type="button" role="tab">
                <i class="bi bi-box-seam me-1"></i>Склад
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="pricing-tab" data-bs-toggle="tab" data-bs-target="#pricing" type="button" role="tab">
                <i class="bi bi-currency-dollar me-1"></i>Ценообразование
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="customers-tab" data-bs-toggle="tab" data-bs-target="#customers" type="button" role="tab">
                <i class="bi bi-people me-1"></i>Покупатели
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button" role="tab">
                <i class="bi bi-star me-1"></i>Отзывы
            </button>
        </li>
    </ul>

    @* Tab Content *@
    <div class="tab-content" id="insightsTabContent">
        @* Sales Forecast Tab *@
        <div class="tab-pane fade show active" id="forecast" role="tabpanel">
            <div id="forecast-content">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                    <p class="mt-3 text-muted">Анализ данных продаж и создание прогноза...</p>
                </div>
            </div>
        </div>

        @* Inventory Tab *@
        <div class="tab-pane fade" id="inventory" role="tabpanel">
            <div id="inventory-content">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                    <p class="mt-3 text-muted">Анализ остатков на складе...</p>
                </div>
            </div>
        </div>

        @* Pricing Tab *@
        <div class="tab-pane fade" id="pricing" role="tabpanel">
            <div id="pricing-content">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                    <p class="mt-3 text-muted">Генерация рекомендаций по ценам...</p>
                </div>
            </div>
        </div>

        @* Customers Tab *@
        <div class="tab-pane fade" id="customers" role="tabpanel">
            <div id="customers-content">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                    <p class="mt-3 text-muted">Анализ поведения покупателей...</p>
                </div>
            </div>
        </div>

        @* Reviews Tab *@
        <div class="tab-pane fade" id="reviews" role="tabpanel">
            <div id="reviews-content">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                    <p class="mt-3 text-muted">Анализ отзывов покупателей...</p>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Track loaded tabs to avoid reloading
        const loadedTabs = new Set();
        let forecastChart = null;

        document.addEventListener('DOMContentLoaded', function() {
            // Load initial tab
            loadSalesForecast();
            loadedTabs.add('forecast');

            // Handle tab changes
            document.querySelectorAll('#insightsTabs button').forEach(tab => {
                tab.addEventListener('shown.bs.tab', function(e) {
                    const targetId = e.target.getAttribute('data-bs-target').replace('#', '');
                    if (!loadedTabs.has(targetId)) {
                        loadedTabs.add(targetId);
                        switch(targetId) {
                            case 'inventory': loadInventoryInsights(); break;
                            case 'pricing': loadPricingRecommendations(); break;
                            case 'customers': loadCustomerInsights(); break;
                            case 'reviews': loadReviewAnalysis(); break;
                        }
                    }
                });
            });
        });

        function refreshAllInsights() {
            loadedTabs.clear();
            loadSalesForecast();
            loadedTabs.add('forecast');
            
            // Reset other tabs to loading state
            ['inventory', 'pricing', 'customers', 'reviews'].forEach(tab => {
                document.getElementById(`${tab}-content`).innerHTML = `
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Загрузка...</span>
                        </div>
                        <p class="mt-3 text-muted">Loading...</p>
                    </div>`;
            });
        }

        async function loadSalesForecast() {
            try {
                const response = await fetch('?handler=SalesForecast');
                const data = await response.json();
                
                if (data.error) {
                    showError('forecast-content', data.error);
                    return;
                }

                renderSalesForecast(data);
            } catch (error) {
                showError('forecast-content', 'Ошибка загрузки прогноза продаж');
            }
        }

        function renderSalesForecast(data) {
            const html = `
                <div class="row g-4">
                    <div class="col-12">
                        <div class="card shadow-lg">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h5 class="card-title mb-1"><i class="bi bi-graph-up-arrow text-primary me-2"></i>30-Day Sales Forecast</h5>
                                        <span class="badge bg-${data.confidence === 'High' ? 'success' : data.confidence === 'Medium' ? 'warning' : 'secondary'}">${data.confidence} Confidence</span>
                                    </div>
                                    <div class="text-end">
                                        <div class="fs-4 fw-bold text-primary">R${formatNumber(data.predictedRevenue)}</div>
                                        <small class="text-${data.predictedGrowthPercent >= 0 ? 'success' : 'danger'}">
                                            <i class="bi bi-arrow-${data.predictedGrowthPercent >= 0 ? 'up' : 'down'}"></i>
                                            ${Math.abs(data.predictedGrowthPercent).toFixed(1)}% predicted
                                        </small>
                                    </div>
                                </div>
                                <p class="text-muted">${data.summary}</p>
                                
                                ${data.forecastData && data.forecastData.length > 0 ? `
                                <div class="mt-4" style="height: 300px;">
                                    <canvas id="forecastChart"></canvas>
                                </div>` : ''}
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="card shadow-lg h-100">
                            <div class="card-header"><i class="bi bi-lightbulb me-2"></i>Ключевые выводы</div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    ${(data.keyInsights || []).map(insight => `
                                        <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>${insight}</li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="card shadow-lg h-100">
                            <div class="card-header"><i class="bi bi-clipboard-check me-2"></i>Рекомендации</div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    ${(data.recommendations || []).map(rec => `
                                        <li class="mb-2"><i class="bi bi-arrow-right-circle text-primary me-2"></i>${rec}</li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                    ${data.seasonalTrends ? `
                    <div class="col-12">
                        <div class="card shadow-lg">
                            <div class="card-header"><i class="bi bi-calendar-event me-2"></i>Сезонный анализ</div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <div class="text-center p-3 bg-success bg-opacity-10 rounded">
                                            <i class="bi bi-sun fs-1 text-success"></i>
                                            <h6 class="mt-2 mb-0">Пиковый сезон</h6>
                                            <p class="mb-0 text-muted">${data.seasonalTrends.peakSeason}</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <div class="text-center p-3 bg-warning bg-opacity-10 rounded">
                                            <i class="bi bi-cloud fs-1 text-warning"></i>
                                            <h6 class="mt-2 mb-0">Тихий сезон</h6>
                                            <p class="mb-0 text-muted">${data.seasonalTrends.slowSeason}</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="p-3">
                                            <h6><i class="bi bi-bar-chart me-2"></i>Patterns</h6>
                                            <ul class="small mb-0">
                                                ${(data.seasonalTrends.seasonalPatterns || []).map(p => `<li>${p}</li>`).join('')}
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>` : ''}
                </div>
            `;
            
            document.getElementById('forecast-content').innerHTML = html;
            
            // Render chart if data exists
            if (data.forecastData && data.forecastData.length > 0) {
                setTimeout(() => renderForecastChart(data.forecastData), 100);
            }
        }

        function renderForecastChart(forecastData) {
            const ctx = document.getElementById('forecastChart');
            if (!ctx) return;
            
            if (forecastChart) forecastChart.destroy();
            
            const labels = forecastData.map(d => new Date(d.date).toLocaleDateString('en-ZA', { month: 'short', day: 'numeric' }));
            const predicted = forecastData.map(d => d.predictedSales);
            const lower = forecastData.map(d => d.lowerBound);
            const upper = forecastData.map(d => d.upperBound);
            
            forecastChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Predicted Sales',
                            data: predicted,
                            borderColor: 'rgb(75, 192, 192)',
                            backgroundColor: 'rgba(75, 192, 192, 0.1)',
                            fill: false,
                            tension: 0.4
                        },
                        {
                            label: 'Upper Bound',
                            data: upper,
                            borderColor: 'rgba(75, 192, 192, 0.3)',
                            backgroundColor: 'transparent',
                            borderDash: [5, 5],
                            fill: false,
                            tension: 0.4
                        },
                        {
                            label: 'Lower Bound',
                            data: lower,
                            borderColor: 'rgba(75, 192, 192, 0.3)',
                            backgroundColor: 'rgba(75, 192, 192, 0.1)',
                            borderDash: [5, 5],
                            fill: '-1',
                            tension: 0.4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': R' + context.parsed.y.toFixed(2);
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) { return 'R' + value.toLocaleString(); }
                            }
                        }
                    }
                }
            });
        }

        async function loadInventoryInsights() {
            try {
                const response = await fetch('?handler=InventoryInsights');
                const data = await response.json();
                
                if (data.error) {
                    showError('inventory-content', data.error);
                    return;
                }

                renderInventoryInsights(data);
            } catch (error) {
                showError('inventory-content', 'Ошибка загрузки аналитики склада');
            }
        }

        function renderInventoryInsights(data) {
            const html = `
                <div class="row g-4">
                    <div class="col-12">
                        <div class="alert alert-info">
                            <i class="bi bi-robot me-2"></i><strong>ИИ-анализ:</strong> ${data.summary}
                        </div>
                    </div>
                    
                    ${data.alerts && data.alerts.length > 0 ? `
                    <div class="col-12">
                        <div class="card shadow-lg border-danger">
                            <div class="card-header bg-danger text-white">
                                <i class="bi bi-exclamation-triangle me-2"></i>Оповещения о складе (${data.alerts.length})
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0 ai-insights-table">
                                        <thead>
                                            <tr>
                                                <th>Товар</th>
                                                <th>Склад</th>
                                                <th>Дней осталось</th>
                                                <th>Степень</th>
                                                <th>Действие</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            ${data.alerts.map(alert => `
                                                <tr>
                                                    <td><a href="/Admin/Products/Edit/${alert.productId}">${alert.productName}</a></td>
                                                    <td>${alert.currentStock}</td>
                                                    <td><span class="badge bg-${alert.alertType === 'Critical' ? 'danger' : 'warning'}">${alert.daysUntilStockout}d</span></td>
                                                    <td><span class="badge bg-${alert.alertType === 'Critical' ? 'danger' : 'warning'}">${alert.alertType}</span></td>
                                                    <td><a href="/Admin/Products/Edit/${alert.productId}" class="btn btn-sm btn-outline-primary">Пополнить</a></td>
                                                </tr>
                                            `).join('')}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>` : ''}
                    
                    <div class="col-md-6">
                        <div class="card shadow-lg h-100">
                            <div class="card-header"><i class="bi bi-lightning me-2"></i>Быстро продаваемые товары</div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush">
                                    ${(data.fastMovingProducts || []).slice(0, 5).map(p => `
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <div>
                                                <a href="/Admin/Products/Edit/${p.productId}" class="text-decoration-none">${p.productName}</a>
                                                <small class="d-block text-muted">${p.unitsSoldLast30Days} продано за 30 дн.</small>
                                            </div>
                                            <span class="badge bg-success rounded-pill">${p.currentStock} в наличии</span>
                                        </li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="card shadow-lg h-100">
                            <div class="card-header"><i class="bi bi-hourglass-split me-2"></i>Медленно продаваемые товары</div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush">
                                    ${(data.slowMovingProducts || []).slice(0, 5).map(p => `
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <div>
                                                <a href="/Admin/Products/Edit/${p.productId}" class="text-decoration-none">${p.productName}</a>
                                                <small class="d-block text-muted">${p.unitsSoldLast30Days} продано за 30 дн. • ${p.currentStock} в наличии</small>
                                            </div>
                                            <span class="badge bg-warning rounded-pill">Рассмотрите акцию</span>
                                        </li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-12">
                        <div class="card shadow-lg">
                            <div class="card-header"><i class="bi bi-clipboard-check me-2"></i>Рекомендации</div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    ${(data.recommendations || []).map(rec => `
                                        <li class="mb-2"><i class="bi bi-arrow-right-circle text-primary me-2"></i>${rec}</li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            document.getElementById('inventory-content').innerHTML = html;
        }

        async function loadPricingRecommendations() {
            try {
                const response = await fetch('?handler=PricingRecommendations');
                const data = await response.json();
                
                if (data.error) {
                    showError('pricing-content', data.error);
                    return;
                }

                renderPricingRecommendations(data);
            } catch (error) {
                showError('pricing-content', 'Ошибка загрузки рекомендаций по ценам');
            }
        }

        function renderPricingRecommendations(data) {
            const html = `
                <div class="row g-4">
                    <div class="col-12">
                        <div class="alert alert-info">
                            <i class="bi bi-robot me-2"></i><strong>ИИ-анализ:</strong> ${data.summary}
                        </div>
                    </div>
                    
                    <div class="col-md-4">
                        <div class="card shadow-lg text-center">
                            <div class="card-body">
                                <i class="bi bi-currency-dollar fs-1 text-success"></i>
                                <h3 class="mt-2 text-success">R${formatNumber(data.potentialRevenueIncrease)}</h3>
                                <p class="text-muted mb-0">Потенциальный рост выручки</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-8">
                        <div class="card shadow-lg h-100">
                            <div class="card-header"><i class="bi bi-lightbulb me-2"></i>Ключевые выводы</div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    ${(data.keyInsights || []).map(insight => `
                                        <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>${insight}</li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                    ${data.recommendations && data.recommendations.length > 0 ? `
                    <div class="col-12">
                        <div class="card shadow-lg">
                            <div class="card-header"><i class="bi bi-tags me-2"></i>Рекомендации по корректировке цен</div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0 ai-insights-table">
                                        <thead>
                                            <tr>
                                                <th>Товар</th>
                                                <th>Текущая</th>
                                                <th>Предлагаемая</th>
                                                <th>Изменение</th>
                                                <th class="reason-col">Причина</th>
                                                <th>Уверенность</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            ${data.recommendations.map(rec => `
                                                <tr>
                                                    <td><a href="/Admin/Products/Edit/${rec.productId}">${rec.productName}</a></td>
                                                    <td>R${rec.currentPrice.toFixed(2)}</td>
                                                    <td class="fw-bold text-primary">R${rec.suggestedPrice.toFixed(2)}</td>
                                                    <td>
                                                        <span class="badge bg-${rec.priceChangePercent > 0 ? 'success' : 'danger'}">
                                                            ${rec.priceChangePercent > 0 ? '+' : ''}${rec.priceChangePercent.toFixed(1)}%
                                                        </span>
                                                    </td>
                                                    <td class="reason-col"><small>${rec.reason}</small></td>
                                                    <td><span class="badge bg-${rec.confidence === 'High' ? 'success' : rec.confidence === 'Medium' ? 'warning' : 'secondary'}">${rec.confidence}</span></td>
                                                </tr>
                                            `).join('')}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>` : '<div class="col-12"><div class="alert alert-secondary">Конкретных рекомендаций по ценообразованию сейчас нет.</div></div>'}
                </div>
            `;
            
            document.getElementById('pricing-content').innerHTML = html;
        }

        async function loadCustomerInsights() {
            try {
                const response = await fetch('?handler=CustomerInsights');
                const data = await response.json();
                
                if (data.error) {
                    showError('customers-content', data.error);
                    return;
                }

                renderCustomerInsights(data);
            } catch (error) {
                showError('customers-content', 'Ошибка загрузки аналитики покупателей');
            }
        }

        function renderCustomerInsights(data) {
            const html = `
                <div class="row g-4">
                    <div class="col-12">
                        <div class="alert alert-info">
                            <i class="bi bi-robot me-2"></i><strong>ИИ-анализ:</strong> ${data.summary}
                        </div>
                    </div>
                    
                    <div class="col-md-3">
                        <div class="card shadow-lg text-center">
                            <div class="card-body">
                                <i class="bi bi-people fs-1 text-primary"></i>
                                <h3 class="mt-2">${data.totalCustomers}</h3>
                                <p class="text-muted mb-0">Всего клиентов</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-lg text-center">
                            <div class="card-body">
                                <i class="bi bi-person-check fs-1 text-success"></i>
                                <h3 class="mt-2">${data.activeCustomers}</h3>
                                <p class="text-muted mb-0">Active (90 days)</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-lg text-center">
                            <div class="card-body">
                                <i class="bi bi-cart fs-1 text-info"></i>
                                <h3 class="mt-2">R${formatNumber(data.averageOrderValue)}</h3>
                                <p class="text-muted mb-0">Средний чек</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-lg text-center">
                            <div class="card-body">
                                <i class="bi bi-gem fs-1 text-warning"></i>
                                <h3 class="mt-2">R${formatNumber(data.customerLifetimeValue)}</h3>
                                <p class="text-muted mb-0">Средняя ценность клиента</p>
                            </div>
                        </div>
                    </div>
                    
                    ${data.churnRiskCustomers && data.churnRiskCustomers.length > 0 ? `
                    <div class="col-md-6">
                        <div class="card shadow-lg h-100 border-warning">
                            <div class="card-header bg-warning bg-opacity-10">
                                <i class="bi bi-exclamation-triangle text-warning me-2"></i>Клиенты с риском оттока
                            </div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush">
                                    ${data.churnRiskCustomers.slice(0, 5).map(c => `
                                        <li class="list-group-item">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <strong>${c.email}</strong>
                                                    <small class="d-block text-muted">Потрачено R${formatNumber(c.totalSpent)} • ${c.daysSinceLastOrder} дн. неактивен</small>
                                                </div>
                                                <span class="badge bg-warning">${(c.churnProbability * 100).toFixed(0)}% risk</span>
                                            </div>
                                            <small class="text-primary"><i class="bi bi-lightbulb me-1"></i>${c.suggestedAction}</small>
                                        </li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>` : ''}
                    
                    ${data.highValueCustomers && data.highValueCustomers.length > 0 ? `
                    <div class="col-md-6">
                        <div class="card shadow-lg h-100 border-success">
                            <div class="card-header bg-success bg-opacity-10">
                                <i class="bi bi-gem text-success me-2"></i>Ценные клиенты
                            </div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush">
                                    ${data.highValueCustomers.slice(0, 5).map(c => `
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <div>
                                                <strong>${c.email}</strong>
                                                <small class="d-block text-muted">${c.orderCount} orders • Avg R${formatNumber(c.averageOrderValue)}</small>
                                            </div>
                                            <span class="badge bg-success">R${formatNumber(c.totalSpent)}</span>
                                        </li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>` : ''}
                    
                    <div class="col-md-6">
                        <div class="card shadow-lg h-100">
                            <div class="card-header"><i class="bi bi-lightbulb me-2"></i>Ключевые выводы</div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    ${(data.keyInsights || []).map(insight => `
                                        <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>${insight}</li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="card shadow-lg h-100">
                            <div class="card-header"><i class="bi bi-clipboard-check me-2"></i>Рекомендации</div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    ${(data.recommendations || []).map(rec => `
                                        <li class="mb-2"><i class="bi bi-arrow-right-circle text-primary me-2"></i>${rec}</li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            document.getElementById('customers-content').innerHTML = html;
        }

        async function loadReviewAnalysis() {
            try {
                const response = await fetch('?handler=ReviewAnalysis');
                const data = await response.json();
                
                if (data.error) {
                    showError('reviews-content', data.error);
                    return;
                }

                renderReviewAnalysis(data);
            } catch (error) {
                showError('reviews-content', 'Ошибка загрузки аналитики отзывов');
            }
        }

        function renderReviewAnalysis(data) {
            const sentimentColor = data.overallSentiment === 'Positive' ? 'success' : 
                                  data.overallSentiment === 'Mixed' ? 'warning' : 'danger';
            
            const html = `
                <div class="row g-4">
                    <div class="col-12">
                        <div class="alert alert-info">
                            <i class="bi bi-robot me-2"></i><strong>ИИ-анализ:</strong> ${data.summary}
                        </div>
                    </div>
                    
                    <div class="col-md-4">
                        <div class="card shadow-lg text-center">
                            <div class="card-body">
                                <i class="bi bi-chat-quote fs-1 text-primary"></i>
                                <h3 class="mt-2">${data.totalReviews}</h3>
                                <p class="text-muted mb-0">Всего отзывов</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-lg text-center">
                            <div class="card-body">
                                <i class="bi bi-star-fill fs-1 text-warning"></i>
                                <h3 class="mt-2">${data.averageRating.toFixed(1)}/5</h3>
                                <p class="text-muted mb-0">Средняя оценка</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-lg text-center">
                            <div class="card-body">
                                <i class="bi bi-emoji-smile fs-1 text-${sentimentColor}"></i>
                                <h3 class="mt-2 text-${sentimentColor}">${data.overallSentiment}</h3>
                                <p class="text-muted mb-0">Общая тональность</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="card shadow-lg h-100 border-success">
                            <div class="card-header bg-success bg-opacity-10">
                                <i class="bi bi-hand-thumbs-up text-success me-2"></i>Частые похвалы
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    ${(data.commonPraises || []).map(praise => `
                                        <li class="mb-2"><i class="bi bi-plus-circle text-success me-2"></i>${praise}</li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="card shadow-lg h-100 border-danger">
                            <div class="card-header bg-danger bg-opacity-10">
                                <i class="bi bi-hand-thumbs-down text-danger me-2"></i>Частые жалобы
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    ${(data.commonComplaints || []).map(complaint => `
                                        <li class="mb-2"><i class="bi bi-dash-circle text-danger me-2"></i>${complaint}</li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                    ${data.reviewAlerts && data.reviewAlerts.length > 0 ? `
                    <div class="col-12">
                        <div class="card shadow-lg border-warning">
                            <div class="card-header bg-warning bg-opacity-10">
                                <i class="bi bi-exclamation-triangle text-warning me-2"></i>Товары, требующие внимания
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0 ai-insights-table">
                                        <thead>
                                            <tr>
                                                <th>Товар</th>
                                                <th>Проблема</th>
                                                <th>Негативных</th>
                                                <th>Действие</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            ${data.reviewAlerts.map(alert => `
                                                <tr>
                                                    <td><a href="/Admin/Products/Edit/${alert.productId}">${alert.productName}</a></td>
                                                    <td><span class="badge bg-${alert.alertType === 'QualityIssue' ? 'danger' : 'warning'}">${alert.alertType}</span></td>
                                                    <td>${alert.recentNegativeCount}</td>
                                                    <td><a href="/Products/${alert.productId}" class="btn btn-sm btn-outline-primary">Просмотр</a></td>
                                                </tr>
                                            `).join('')}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>` : ''}
                    
                    ${data.productSentiments && data.productSentiments.length > 0 ? `
                    <div class="col-12">
                        <div class="card shadow-lg">
                            <div class="card-header"><i class="bi bi-bar-chart me-2"></i>Тональность отзывов</div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0 ai-insights-table">
                                        <thead>
                                            <tr>
                                                <th>Товар</th>
                                                <th>Отзывы</th>
                                                <th>Рейтинг</th>
                                                <th>Тональность</th>
                                                <th>Тренд</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            ${data.productSentiments.slice(0, 10).map(p => `
                                                <tr>
                                                    <td><a href="/Admin/Products/Edit/${p.productId}">${p.productName}</a></td>
                                                    <td>${p.reviewCount}</td>
                                                    <td>
                                                        <span class="text-warning">${'★'.repeat(Math.round(p.averageRating))}${'☆'.repeat(5-Math.round(p.averageRating))}</span>
                                                        ${p.averageRating.toFixed(1)}
                                                    </td>
                                                    <td><span class="badge bg-${p.sentiment === 'Positive' ? 'success' : p.sentiment === 'Mixed' ? 'warning' : 'danger'}">${p.sentiment}</span></td>
                                                    <td>
                                                        <span class="text-${p.sentimentTrend === 'Improving' ? 'success' : p.sentimentTrend === 'Declining' ? 'danger' : 'secondary'}">
                                                            <i class="bi bi-arrow-${p.sentimentTrend === 'Improving' ? 'up' : p.sentimentTrend === 'Declining' ? 'down' : 'right'}"></i>
                                                            ${p.sentimentTrend}
                                                        </span>
                                                    </td>
                                                </tr>
                                            `).join('')}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>` : ''}
                    
                    <div class="col-12">
                        <div class="card shadow-lg">
                            <div class="card-header"><i class="bi bi-clipboard-check me-2"></i>Рекомендации</div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    ${(data.recommendations || []).map(rec => `
                                        <li class="mb-2"><i class="bi bi-arrow-right-circle text-primary me-2"></i>${rec}</li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            document.getElementById('reviews-content').innerHTML = html;
        }

        function showError(containerId, message) {
            document.getElementById(containerId).innerHTML = `
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>${message}
                </div>
            `;
        }

        function formatNumber(num) {
            if (num === null || num === undefined) return '0';
            return num.toLocaleString('en-ZA', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
    </script>
}
</div>
