@page
@model StorefrontRazor.Pages.Admin.ProductOptions.IndexModel
@{
    ViewData["Title"] = "Опции товаров";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@ViewData["Title"]</h1>
    <a asp-page="./Create" class="btn btn-primary">
        <i class="bi bi-plus-circle-fill me-2"></i>Создать
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (Model.Options.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Название</th>
                            <th class="text-center">Значения</th>
                            <th style="width: 150px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var option in Model.Options)
                        {
                            <tr>
                                <td>@option.Id</td>
                                <td>@option.Name</td>
                                <td class="text-center">
                                    <span class="badge bg-secondary rounded-pill">@option.ValueCount</span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex flex-wrap justify-content-end gap-2">
                                        <a asp-page="./Edit" asp-route-id="@option.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@option.Id" class="d-inline" onsubmit="return confirm('Вы уверены, что хотите удалить этот элемент?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            @* --- This card is shown if no options exist --- *@
            <div class="text-center p-4">
                <h4 class="text-muted">Данные отсутствуют.</h4>
                <p>Создайте первую опцию (напр., «Цвет», «Размер»).</p>
                <a asp-page="./Create" class="btn btn-primary mt-2">
                    <i class="bi bi-plus-circle-fill me-2"></i>Создать
                </a>
            </div>
        }
    </div>
</div>