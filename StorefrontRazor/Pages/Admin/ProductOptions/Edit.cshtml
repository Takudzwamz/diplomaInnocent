@page "{id:int}"
@model StorefrontRazor.Pages.Admin.ProductOptions.EditModel
@{
    ViewData["Title"] = "Редактировать";
}

<h1>@ViewData["Title"]: @Model.OptionToUpdate.Name</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-3">
                <label asp-for="OptionToUpdate.Name" class="form-label"></label>
                <input asp-for="OptionToUpdate.Name" class="form-control" />
                <span asp-validation-for="OptionToUpdate.Name" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Значения опции</label>
                <div class="form-text mb-2">Редактируйте значения. Для цветов можно указать HEX-код (напр., #FF0000 для красного). Удаление значения из списка удалит его.</div>
                
                <div id="values-container">
                    <!-- Existing values will be populated here -->
                </div>
                
                <button type="button" class="btn btn-outline-secondary mt-2" id="add-value-btn">
                    <i class="bi bi-plus-circle"></i> Добавить значение
                </button>
            </div>

            <input type="hidden" asp-for="OptionToUpdate.Values" id="values-input" />

            <div class="d-flex justify-content-between mt-4">
                <a asp-page="./Index" class="btn btn-outline-secondary">Отмена</a>
                <button type="submit" class="btn btn-primary">Сохранить</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const container = document.getElementById('values-container');
            const addBtn = document.getElementById('add-value-btn');
            const valuesInput = document.getElementById('values-input');
            
            // Parse existing values from the hidden input
            const existingValues = '@Html.Raw(Model.OptionToUpdate.Values ?? "")';

            function createValueRow(name = '', colorHex = '') {
                const row = document.createElement('div');
                row.className = 'value-row d-flex gap-2 mb-2 align-items-center';
                
                // Determine the color picker value
                const pickerColor = colorHex && /^#[0-9A-Fa-f]{6}$/i.test(colorHex) ? colorHex : '#ffffff';
                
                row.innerHTML = `
                    <input type="text" class="form-control value-name" placeholder="Value name (e.g., Red, Small)" value="${escapeHtml(name)}" required style="flex: 2;" />
                    <div class="input-group" style="flex: 1;">
                        <input type="color" class="form-control form-control-color color-picker" value="${pickerColor}" title="Выбрать цвет (необязательно)">
                        <input type="text" class="form-control color-hex" placeholder="#FFFFFF" value="${escapeHtml(colorHex)}" maxlength="7" style="width: 90px;">
                    </div>
                    <button type="button" class="btn btn-outline-danger btn-sm remove-value-btn">
                        <i class="bi bi-trash"></i>
                    </button>
                `;
                
                // Color preview swatch
                const colorHexInput = row.querySelector('.color-hex');
                const colorPicker = row.querySelector('.color-picker');
                
                colorPicker.addEventListener('input', function() {
                    colorHexInput.value = this.value.toUpperCase();
                    updateValuesInput();
                });
                
                colorHexInput.addEventListener('input', function() {
                    let val = this.value;
                    if (val && !val.startsWith('#')) val = '#' + val;
                    if (/^#[0-9A-Fa-f]{6}$/.test(val)) {
                        colorPicker.value = val;
                    }
                    updateValuesInput();
                });
                
                row.querySelector('.value-name').addEventListener('input', updateValuesInput);
                row.querySelector('.remove-value-btn').addEventListener('click', function() {
                    row.remove();
                    updateValuesInput();
                });
                
                container.appendChild(row);
                updateValuesInput();
            }

            function escapeHtml(text) {
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            function updateValuesInput() {
                const rows = container.querySelectorAll('.value-row');
                const values = [];
                rows.forEach(row => {
                    const name = row.querySelector('.value-name').value.trim();
                    const colorHex = row.querySelector('.color-hex').value.trim();
                    if (name) {
                        // Format: Name|ColorHex or just Name
                        values.push(colorHex ? `${name}|${colorHex}` : name);
                    }
                });
                valuesInput.value = values.join(',');
            }

            addBtn.addEventListener('click', function() {
                createValueRow();
            });

            // Parse and populate existing values
            if (existingValues) {
                const items = existingValues.split(',');
                items.forEach(item => {
                    const trimmed = item.trim();
                    if (trimmed) {
                        const parts = trimmed.split('|');
                        const name = parts[0].trim();
                        const colorHex = parts.length > 1 ? parts[1].trim() : '';
                        createValueRow(name, colorHex);
                    }
                });
            }
            
            // If no values exist, add an empty row
            if (container.children.length === 0) {
                createValueRow();
            }
        });
    </script>
}