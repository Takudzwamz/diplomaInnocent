@page
@model StorefrontRazor.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Пользователи";
}

@if(TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if(TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@ViewData["Title"]</h1>
    <a asp-page="./Create" class="btn btn-primary">
        <i class="bi bi-plus-circle-fill me-2"></i>Создать
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Email</th>
                        <th>Роль(и)</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @* 1. UPDATE FOREACH LOOP *@
                    @foreach (var user in Model.UserPagination.Data)
                    {
                        <tr>
                            <td>@user.FirstName @user.LastName</td>
                            <td>@user.Email</td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    <span class="badge @(role == "Admin" ? "bg-primary" : "bg-secondary")">@role</span>
                                }
                                @if (!user.Roles.Any())
                                {
                                    <span class="badge bg-light text-dark">Покупатель</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (user.Email.Equals("admin@production.com", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge bg-light-subtle text-dark-emphasis border border-dark-subtle">Супер-админ (нельзя изменить)</span>
                                }
                                else
                                {
                                    <div class="d-flex flex-wrap justify-content-end gap-2">
                                        <a asp-page="./Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        @* 2. ADD PAGEINDEX TO DELETE FORM *@
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" asp-route-pageIndex="@Model.PageIndex" class="d-inline" onsubmit="return confirm('Вы уверены, что хотите удалить этот элемент?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* 3. ADD PAGINATION CONTROLS *@
@if (Model.UserPagination.TotalPages > 1)
{
    <div class="d-flex justify-content-center mt-4">
        <nav>
            <ul class="pagination">
                @{
                    var currentPage = Model.PageIndex;
                    var totalPages = Model.UserPagination.TotalPages;
                    var maxPagesToShow = 5;
                    var startPage = 1;
                    var endPage = totalPages;

                    if (totalPages > maxPagesToShow)
                    {
                        var pagesToShowHalf = maxPagesToShow / 2;
                        startPage = Math.Max(1, currentPage - pagesToShowHalf);
                        endPage = startPage + maxPagesToShow - 1;

                        if (endPage > totalPages)
                        {
                            endPage = totalPages;
                            startPage = Math.Max(1, endPage - maxPagesToShow + 1);
                        }
                    }

                    // --- Previous Button ---
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a asp-page="/Admin/Users/Index" asp-route-PageIndex="@(currentPage - 1)"
                           class="page-link" aria-label="Previous" tabindex="@(currentPage == 1 ? "-1" : null)">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>

                    // --- First Page ---
                    @if (startPage > 1)
                    {
                        <li class="page-item">
                            <a asp-page="/Admin/Users/Index" asp-route-PageIndex="1" class="page-link">1</a>
                        </li>
                        @if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    // --- Page Numbers ---
                    @for (var i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a asp-page="/Admin/Users/Index" asp-route-PageIndex="@i" class="page-link">@i</a>
                        </li>
                    }

                    // --- Last Page ---
                    @if (endPage < totalPages)
                    {
                        @if (endPage < totalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a asp-page="/Admin/Users/Index" asp-route-PageIndex="@totalPages" class="page-link">@totalPages</a>
                        </li>
                    }

                    // --- Next Button ---
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a asp-page="/Admin/Users/Index" asp-route-PageIndex="@(currentPage + 1)"
                           class="page-link" aria-label="Next" tabindex="@(currentPage == totalPages ? "-1" : null)">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}