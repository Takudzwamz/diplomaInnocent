@using Core.Interfaces
@inject ISiteSettingsService SettingsService
@{
    var settings = await SettingsService.GetSettingsAsync();
    var storeName = settings.GetValueOrDefault("StoreName");
    var faviconUrl = settings.GetValueOrDefault("StoreFaviconUrl");

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - @storeName Admin Panel</title>
    @if (!string.IsNullOrEmpty(faviconUrl))
    {
        <link rel="icon" href="@faviconUrl" type="image/x-icon" />
    }
    else
    {
        <link rel="icon" href="~/favicon.ico" type="image/x-icon" />
    }
    <script>
        (() => {
            const getStoredTheme = () => localStorage.getItem('theme');
            const getPreferredTheme = () => {
                const storedTheme = getStoredTheme();
                if (storedTheme) return storedTheme;
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            };
            const theme = getPreferredTheme();
            if (theme) document.documentElement.setAttribute('data-bs-theme', theme);
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Head", required: false)
</head>

<body>
    <div class="bg-animation">
        <div class="floating-orb orb1"></div>
        <div class="floating-orb orb2"></div>
        <div class="floating-orb orb3"></div>
    </div>
    @* --- FIX #1: Main container for the two-column layout --- *@
    <div class="d-lg-flex" style="min-height: 100vh;">

        @* --- FIX #2: Sidebar is now a Bootstrap Offcanvas component --- *@
        <nav class="bg-body-tertiary shadow-lg p-3 d-flex flex-column offcanvas-lg offcanvas-start" tabindex="-1"
            id="adminSidebar" aria-labelledby="adminSidebarLabel" style="width: 280px; min-width: 280px; flex-shrink: 0;">

            <div class="offcanvas-header">
                <h4 class="offcanvas-title" id="adminSidebarLabel">
                    <i class="bi bi-shield-lock-fill me-2"></i>Панель управления
                </h4>
                <button type="button" class="btn-close " data-bs-dismiss="offcanvas" data-bs-target="#adminSidebar"
                    aria-label="Close"></button>
            </div>

            <div class="offcanvas-body d-flex flex-column p-0">
                <ul class="nav nav-pills flex-column mb-auto">
                    <li class="nav-item mt-3">
                        <h6
                            class="sidebar-heading d-flex justify-content-between align-items-center px-3 mb-1  text-uppercase">
                            <span>Панель управления</span>
                        </h6>
                    </li>
                    <li class="nav-item">
                        <a asp-page="/Admin/Index"
                            class="nav-link  @(ViewData["Title"]?.ToString() == "Dashboard" ? "active" : "")">
                            <i class="bi bi-speedometer2 me-2"></i> Панель управления
                        </a>
                    </li>
                    <li class="nav-item mt-3">
                        <a asp-page="/Admin/AIInsights/Index"
                            class="nav-link @(ViewData["Title"]?.ToString() == "AI Insights" ? "active" : "")">
                            <i class="bi bi-robot me-2"></i> AI-аналитика
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-page="/Admin/Recommendations/Index"
                            class="nav-link @(ViewData["Title"]?.ToString() == "Recommendations & A/B Tests" ? "active" : "")">
                            <i class="bi bi-graph-up me-2"></i> Рекомендации
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-page="/Admin/Recommendations/Evaluation"
                            class="nav-link @(ViewData["Title"]?.ToString() == "Offline Evaluation" ? "active" : "")">
                            <i class="bi bi-clipboard-data me-2"></i> Офлайн-оценка
                        </a>
                    </li>
                    <hr class="my-2">
                    <li class="nav-item mt-3">
                        <h6
                            class="sidebar-heading d-flex justify-content-between align-items-center px-3 mb-1  text-uppercase">
                            <span>Продажи</span>
                        </h6>
                    </li>
                    <li class="mb-2">
                        <a asp-page="/Admin/Orders/Index"
                            class="nav-link  @(ViewData["Title"]?.ToString().Contains("Order") ?? false ? "active" : "")">
                            <i class="bi bi-receipt-cutoff me-2"></i> Заказы
                        </a>
                    </li>
                    <li>
                        <a asp-page="/Admin/Products/TopSelling"
                            class="nav-link @(currentPage.StartsWith("/Admin/Products/TopSelling") ? "active" : "")">
                            <i class="bi bi-graph-up-arrow me-2"></i> Лидеры продаж
                        </a>
                    </li>
                    <hr class="my-2">
                    <li class="nav-item mt-3">
                        <h6
                            class="sidebar-heading d-flex justify-content-between align-items-center px-3 mb-1  text-uppercase">
                            <span>Каталог</span>
                        </h6>
                    <li class="mb-2">
                        <a asp-page="/Admin/Products/Index"
                            class="nav-link @(currentPage == "/Admin/Products/Index" || currentPage.StartsWith("/Admin/Products/Create") || currentPage.StartsWith("/Admin/Products/Edit") ? "active" : "")">
                            <i class="bi bi-box-seam-fill me-2"></i> Товары
                        </a>
                    </li>

                    <li class="mb-2">
                        <a asp-page="/Admin/ProductOptions/Index"
                            class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString().StartsWith("/Admin/ProductOptions") ?? false ? "active" : "")">
                            <i class="bi bi-sliders me-2"></i> Опции товаров
                        </a>
                    </li>

                    <li class="mb-2">
                        <a asp-page="/Admin/Coupons/Index"
                            class="nav-link  @(ViewData["Title"]?.ToString().Contains("Coupon") ?? false ? "active" : "")">
                            <i class="bi bi-ticket-fill me-2"></i> Купоны
                        </a>
                    </li>
                    <li class="mb-2">
                        <a asp-page="/Admin/Categories/Index"
                            class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Categories/Index" ? "active" : "")">
                            <i class="bi bi-tags-fill me-2"></i> Категории
                        </a>

                    </li>

                    <li class="mb-2">
                        <a asp-page="/Admin/Brands/Index"
                            class="nav-link  @(ViewData["Title"]?.ToString().Contains("Brand") ?? false ? "active" : "")">
                            <i class="bi bi-tags-fill me-2"></i> Бренды
                        </a>
                    </li>
                    <li class="mb-2">
                        <a asp-page="/Admin/Types/Index"
                            class="nav-link  @(ViewData["Title"]?.ToString().Contains("Type") ?? false ? "active" : "")">
                            <i class="bi bi-bookmark-fill me-2"></i> Типы
                        </a>
                    </li>

                    <hr class="my-2">
                    <li class="nav-item mt-3">
                        <h6
                            class="sidebar-heading d-flex justify-content-between align-items-center px-3 mb-1  text-uppercase">
                            <span>Способы доставки</span>
                        </h6>
                    </li>
                    <li>
                        <a asp-page="/Admin/DeliveryMethods/Index"
                            class="nav-link  @(ViewData["Title"]?.ToString().Contains("Delivery Method") ?? false ? "active" : "")">
                            <i class="bi bi-truck me-2"></i> Способы доставки
                        </a>
                    </li>
                    <hr class="my-2">
                    <li class="nav-item mt-3">
                        <h6
                            class="sidebar-heading d-flex justify-content-between align-items-center px-3 mb-1  text-uppercase">
                            <span>Покупатели</span>
                        </h6>
                    </li>
                    <li>
                        <a asp-page="/Admin/Customers/Index"
                            class="nav-link  @(ViewData["Title"]?.ToString().Contains("Customer") ?? false ? "active" : "")">
                            <i class="bi bi-people-fill me-2"></i> Покупатели
                        </a>
                    </li>

                    <hr class="my-2">
                    <li class="nav-item mt-3">
                        <h6
                            class="sidebar-heading d-flex justify-content-between align-items-center px-3 mb-1  text-uppercase">
                            <span>Управление контентом</span>
                        </h6>
                    </li>
                    <li class="mb-2">
                        <a asp-page="/Admin/Content/Index"
                            class="nav-link  @(ViewData["Title"]?.ToString().Contains("Content") ?? false ? "active" : "")">
                            <i class="bi bi-file-text-fill me-2"></i> Блоки контента
                        </a>
                    </li>
                    <li class="mb-2">
                        <a asp-page="/Admin/Hero/Index"
                            class="nav-link  @(ViewData["Title"]?.ToString().Contains("Hero") ?? false ? "active" : "")">
                            <i class="bi bi-images me-2"></i> Карусель баннеров
                        </a>
                    </li>
                    <li class="mb-2">
                        <a asp-page="/Admin/Faqs/Index"
                            class="nav-link @(ViewData["Title"]?.ToString().Contains("FAQ") ?? false ? "active" : "")">
                            <i class="bi bi-question-circle-fill me-2"></i> Управление FAQ
                        </a>
                    </li>
                    <hr class="my-2">
                    <li class="nav-item mt-3">
                        <h6
                            class="sidebar-heading d-flex justify-content-between align-items-center px-3 mb-1 text-uppercase">
                            <span>Настройки</span>
                        </h6>
                    </li>
                    <li class="mb-2">
                        @* --- THIS IS THE FIX --- *@
                        <a asp-page="/Admin/Settings/Index"
                            class="nav-link @(currentPage == "/Admin/Settings/Index" ? "active" : "")">
                            <i class="bi bi-gear-fill me-2"></i> Настройки сайта
                        </a>
                    </li>
                    <li class="mb-2">
                        @* --- THIS IS THE FIX --- *@
                        <a asp-page="/Admin/Settings/Payment"
                            class="nav-link @(currentPage == "/Admin/Settings/Payment" ? "active" : "")">
                            <i class="bi bi-credit-card-fill me-2"></i> Настройки оплаты
                        </a>
                    </li>

                    <li class="mb-2">
                        <a asp-page="/Admin/Users/Index"
                            class="nav-link @(currentPage.StartsWith("/Admin/Users") ? "active" : "")">
                            <i class="bi bi-people-fill me-2"></i> Управление пользователями
                        </a>
                    </li>

                    <hr class="my-2">
                    <li class="nav-item mt-3">
                        <h6
                            class="sidebar-heading d-flex justify-content-between align-items-center px-3 mb-1  text-uppercase">
                            <span>Маркетинг</span>
                        </h6>
                    </li>
                    <li class="mb-2">
                        <a asp-page="/Admin/Marketing/Index"
                            class="nav-link  @(ViewData["Title"]?.ToString().Contains("Marketing") ?? false ? "active" : "")">
                            <i class="bi bi-megaphone-fill me-2"></i> Email-рассылки
                        </a>
                    </li>
                    <li class="mb-2">
                        <a asp-page="/Admin/Marketing/Templates/Index"
                            class="nav-link @(ViewData["Title"]?.ToString().Contains("Template") ?? false ? "active" : "")">
                            <i class="bi bi-journal-richtext me-2"></i> Управление шаблонами
                        </a>
                    </li>
                    <hr class="my-3">
                    <li>
                        <partial name="_ThemeSwitcherPartial" />
                    </li>

                </ul>
                <hr>

                <div class="px-3 pb-3">
                    <a asp-page="/Index" class="btn btn-primary w-100"><i
                            class="bi bi-arrow-left-circle-fill me-2"></i>Назад</a>
                </div>
            </div>
        </nav>

        <div class="flex-grow-1 d-flex flex-column">
            @* --- FIX #3: Added a header with a toggle button, only visible on small screens --- *@
            <header class="navbar bg-body-tertiary shadow-sm d-lg-none sticky-top">
                <div class="container-fluid">
                    <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#adminSidebar" aria-controls="adminSidebar">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <span class="navbar-brand mb-0 h1">Меню администратора</span>
                </div>
            </header>

            <main class="p-4" style="">
                @RenderBody()
            </main>
            <footer class="footer bg-body-tertiary border-top text-muted mt-auto py-3">
                <div class="container-fluid text-center">
                    <p class="mb-2">
                        &copy; @DateTime.Now.Year - @storeName. Панель администратора. Все права защищены.
                    </p>
                    <p class="mb-0 small">
                        Разработано <a href="https://sputnikdevs.com" target="_blank"
                            class="text-primary text-decoration-none">Sputnik Devs (Pty) Ltd</a>
                    </p>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/theme-switcher.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>