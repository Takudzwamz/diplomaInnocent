@page
@model StorefrontRazor.Pages.Orders.ConfirmationModel
@{
    ViewData["Title"] = "Статус заказа";
}

<div class="container mt-5">

    @if (Model.Order != null)
    {
        @if (Model.IsSuccess)
        {
            <div class="text-center card p-5 border rounded shadow-sm ">
                <h1 class="text-success"><i class="bi bi-check-circle-fill"></i></h1>
                <h2>Заказ подтверждён!</h2>
                <p class="text-muted">Спасибо за ваш заказ. Вы получите подтверждение на электронную почту.</p>
                <p><strong>Заказ №@Model.Order.Id</strong></p>
                <div class="mt-4">
                    <a asp-page="./Details" asp-route-id="@Model.Order.Id" class="btn btn-info">Посмотреть заказ</a>
                    <a asp-page="/Orders/Index" class="btn btn-primary ms-2">Заказы</a>
                    <a asp-page="/Products/Index" class="btn btn-outline-secondary ms-2 my-2">Продолжить покупки</a>
                </div>
            </div>

            @* --- POST-PURCHASE RECOMMENDATIONS --- *@
            @if (Model.AdaptiveRecommendations.Any() || Model.CollaborativeRecommendations.Any() || Model.PopularRecommendations.Any())
            {
                <hr class="my-5" />
                <h3 class="text-center mb-4">Вам также может понравиться</h3>

                @if (Model.AdaptiveRecommendations.Any())
                {
                    <div class="mb-5">
                        <h5 class="text-center mb-3">
                            <i class="bi bi-shuffle text-primary"></i> <span class="rec-info-trigger" data-bs-toggle="modal" data-bs-target="#modal-adaptive">Персональная подборка (Adaptive/Hybrid) <i class="bi bi-info-circle small"></i></span>
                        </h5>
                        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
                            @foreach (var product in Model.AdaptiveRecommendations)
                            {
                                <div class="col" data-rec-strategy="Adaptive">
                                    <partial name="_ProductCardPartial" model="product" />
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (Model.CollaborativeRecommendations.Any())
                {
                    <div class="mb-5">
                        <h5 class="text-center mb-3">
                            <i class="bi bi-people-fill text-info"></i> <span class="rec-info-trigger" data-bs-toggle="modal" data-bs-target="#modal-collaborative">Покупатели с похожими заказами берут <i class="bi bi-info-circle small"></i></span>
                        </h5>
                        <p class="text-center text-muted small">Коллаборативная фильтрация</p>
                        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
                            @foreach (var product in Model.CollaborativeRecommendations)
                            {
                                <div class="col" data-rec-strategy="Collaborative">
                                    <partial name="_ProductCardPartial" model="product" />
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (Model.PopularRecommendations.Any())
                {
                    <div class="mb-5">
                        <h5 class="text-center mb-3">
                            <i class="bi bi-fire text-danger"></i> <span class="rec-info-trigger" data-bs-toggle="modal" data-bs-target="#modal-popular">Популярные товары <i class="bi bi-info-circle small"></i></span>
                        </h5>
                        <p class="text-center text-muted small">Popularity-Based рекомендации</p>
                        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
                            @foreach (var product in Model.PopularRecommendations)
                            {
                                <div class="col" data-rec-strategy="Popular">
                                    <partial name="_ProductCardPartial" model="product" />
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        }
        else
        {
            <div class="text-center card p-5 border rounded shadow-sm ">
                <h1 class="text-danger"><i class="bi bi-x-circle-fill"></i></h1>
                <h2>Ошибка оплаты</h2>
                <p class="text-muted">К сожалению, не удалось обработать ваш платёж. Пожалуйста, попробуйте снова.</p>
                <p>Вы можете повторить оплату на странице деталей заказа.</p>
                <div class="mt-4">
                    <a asp-page="/Orders/Details" asp-route-id="@Model.Order.Id" class="btn btn-warning">Посмотреть заказ и повторить оплату</a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center card p-5 border rounded shadow-sm ">
            <h1 class="text-info"><i class="bi bi-hourglass-split"></i></h1>
            <h2>Оплата обрабатывается...</h2>
            <p class="text-muted">Ваш заказ подтверждается. Пожалуйста, проверьте страницу «Мои заказы» через несколько минут или обновите эту страницу.</p>
            <div class="mt-4">
                <a asp-page="/Orders/Index" class="btn btn-primary">Мои заказы</a>
            </div>
        </div>
    }
</div>

<partial name="Shared/_RecommendationInfoModals" />
