@page
@model StorefrontRazor.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Забыли пароль?";
    Layout = "_AuthLayout";
}

<div class="text-center">
    <h1 class="h3 mb-3 fw-normal">Забыли пароль?</h1>
</div>

@if (Model.Message != null)
{
    <div class="alert alert-success text-center">
        <p>@Model.Message</p>
        <a asp-page="./Login" class="alert-link">Вернуться к входу</a>
    </div>
}
else
{
    <p class="text-center text-muted mb-4">
        Ничего страшного. Введите ваш email, и мы отправим вам ссылку для сброса пароля.
    </p>
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="email@пример.ru" aria-required="true" />
            <label asp-for="Input.Email" class="form-label"></label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        <button type="submit" class="w-100 btn btn-lg btn-primary">Отправить ссылку</button>
    </form>
    <hr class="my-4">
    <div class="text-center">
        <a asp-page="./Login"><i class="bi bi-arrow-left"></i> Назад к входу</a>
    </div>
}
