@page
@model StorefrontRazor.Pages.Account.MyWishlistModel
@{
    ViewData["Title"] = "Избранное";
}

<div class="container mt-5">
    <h1>@ViewData["Title"]</h1>

    @if (!Model.WishlistItems.Any())
    {
        <div class="text-center p-5 border rounded  mt-4">
            <h4>Ваш список избранного пуст.</h4>
            <p class="text-muted">Откройте для себя наши товары и сохраняйте избранное!</p>
            <a asp-page="/Products/Index" class="btn btn-primary mt-3">Найти товары</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4 mt-3">
            @foreach (var item in Model.WishlistItems)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-lg product-card">
                        <a asp-page="/Products/Details" asp-route-returnUrl="@(ViewContext.HttpContext.Request.Path + ViewContext.HttpContext.Request.QueryString)" asp-route-id="@item.ProductId">
                            <img src="@item.Product.PictureUrl" class="card-img-top img-fluid product-img" alt="@item.Product.Name" >
                        </a>
                        <div class="card-body d-flex flex-column product-card-body">
                            <h5 class="card-title">
                                <a asp-page="/Products/Details" asp-route-returnUrl="@(ViewContext.HttpContext.Request.Path + ViewContext.HttpContext.Request.QueryString)" asp-route-id="@item.ProductId" class="text-decoration-none">@item.Product.Name</a>
                            </h5>
                            <div class="mt-auto">
                                <p class="fw-bold fs-5 text-primary">@item.Product.Price.ToString("C")</p>
                                <div class="d-grid gap-2">
                                    <a asp-page="/Products/Details" asp-route-returnUrl="@(ViewContext.HttpContext.Request.Path + ViewContext.HttpContext.Request.QueryString)" asp-route-id="@item.ProductId" class="btn btn-primary">Посмотреть товар</a>
                                    <form method="post" asp-page-handler="RemoveItem" asp-route-itemId="@item.Id">
                                        <button type="submit" class="btn btn-outline-danger w-100">Удалить</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>